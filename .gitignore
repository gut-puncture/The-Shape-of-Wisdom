# Environment files with secrets
.env
.env.local
.env.*.local
.secrets/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temp files
*.tmp
*.temp

# Large archives (never commit)
*.tar.gz

# Experiment outputs / caches (never commit)
runs/*

# Ignore all artifacts by default, but keep the deterministic parser regression suite in-repo.
artifacts/*
!artifacts/parser_edge_case_regression/
artifacts/parser_edge_case_regression/*
!artifacts/parser_edge_case_regression/regression_cases.json

# Paid/large inputs and derived data (never commit raw data)
data/

# GPU downloads (large, never commit)
downloads/

# Legacy archive (kept local only; never commit)
v1/

# Paper build artifacts (keep vector figure PDFs under paper/final_paper/figures/)
paper/final_paper/*.png
paper/final_paper/paper_publish*.pdf
